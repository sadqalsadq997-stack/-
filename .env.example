# ══════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعبئ القيم
# لا ترفع .env على GitHub أبداً
# ══════════════════════════════════════════════════════

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# مفتاح التوقيع للدفع (اختر رمزاً عشوائياً 32+ حرف)
VITE_PAYMENT_SECRET=CHANGE_ME_USE_RANDOM_64_CHARS

# Moyasar — الخصم التلقائي المتكرر (هذا المفتاح "العام" فقط، آمن للواجهة الأمامية)
# المفتاح السري (sk_...) لا يوضع هنا أبداً — فقط في Supabase Edge Functions Secrets
VITE_MOYASAR_PUBLISHABLE_KEY=pk_live_jqWYhUwgKEH3o4tGxHyS8GLWKRvBQLC4j5k9Y3Pv

# AI
VITE_GEMINI_API_KEY=your_gemini_key

# Server
VITE_APP_HOST=your-server-ip-or-domain
